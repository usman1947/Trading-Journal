// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  name         String
  avatarUrl    String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  // Relations
  accounts     Account[]
  trades       Trade[]
  strategies   Strategy[]
  tags         Tag[]
  journals     DailyJournal[]
  settings     Settings?
  coachReports WeeklyCoachReport[]
}

model Account {
  id             String     @id @default(cuid())
  name           String
  description    String?
  isSwingAccount Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  trades         Trade[]
  settings       Settings[]
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String

  @@unique([userId, name])
}

model Trade {
  id                 String           @id @default(cuid())
  symbol             String
  side               String           // LONG, SHORT
  tradeTime          DateTime         // When the trade was taken (entry time)
  exitTime           DateTime?        // When the trade was closed (exit time)
  setup              String?          // Trade setup description
  risk               Float            // Risk amount in dollars
  result             Float?           // P&L result in dollars
  partials           String?          // JSON array of partial results for swing trades
  commission         Float            @default(0) // Commission/fees paid for this trade
  execution          String           @default("PASS") // PASS, FAIL
  isBreakEven        Boolean          @default(false) // Break even trade - excluded from P&L analytics
  notes              String?
  // AI-ready fields
  preTradeMood       String?          // CONFIDENT, ANXIOUS, FOMO, REVENGE, CALM, NEUTRAL
  postTradeMood      String?          // SATISFIED, FRUSTRATED, RELIEVED, REGRETFUL, NEUTRAL
  confidenceLevel    Int?             // 1-10 pre-trade conviction
  mistake            String?          // FOMO, CHASING, EARLY_EXIT, OVERSIZE, REVENGE, NO_PLAN, IGNORED_STOP, etc.
  sentimentScore     Float?           // AI-computed from notes (-1 to 1)
  sequenceInSession  Int?             // Calculated: trade # that day (1st, 2nd, 3rd...)
  holdDurationMins   Int?             // Calculated: exitTime - tradeTime in minutes
  screenshots        Screenshot[]
  embedding          TradeEmbedding?
  strategy           Strategy?        @relation(fields: [strategyId], references: [id])
  strategyId         String?
  account            Account?         @relation(fields: [accountId], references: [id])
  accountId          String?          // null means Paper Account
  tags               TagOnTrade[]
  ruleChecks         TradeRuleCheck[]
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId             String
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model Strategy {
  id              String              @id @default(cuid())
  name            String
  description     String?
  setups          String?             // JSON array of setup names
  isSwingStrategy Boolean             @default(false)
  trades          Trade[]
  rules           StrategyRule[]
  screenshots     StrategyScreenshot[]
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([userId, name])
}

model StrategyRule {
  id          String           @id @default(cuid())
  strategyId  String
  strategy    Strategy         @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  text        String           // The rule/checklist item text
  order       Int              @default(0) // For ordering rules
  tradeChecks TradeRuleCheck[]
  createdAt   DateTime         @default(now())
}

model StrategyScreenshot {
  id          String   @id @default(cuid())
  strategyId  String
  strategy    Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  filename    String
  path        String   // Cloudinary URL
  publicId    String?  // Cloudinary public_id for deletion
  caption     String?  // Optional caption for the example screenshot
  createdAt   DateTime @default(now())
}

model TradeRuleCheck {
  id         String       @id @default(cuid())
  tradeId    String
  trade      Trade        @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  ruleId     String
  rule       StrategyRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  checked    Boolean      @default(false)
  createdAt  DateTime     @default(now())

  @@unique([tradeId, ruleId])
}

model Tag {
  id     String       @id @default(cuid())
  name   String
  color  String       @default("#1976d2")
  trades TagOnTrade[]
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@unique([userId, name])
}

model TagOnTrade {
  trade   Trade  @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  tradeId String
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId   String

  @@id([tradeId, tagId])
}

model Screenshot {
  id        String   @id @default(cuid())
  filename  String
  path      String   // Cloudinary URL
  publicId  String?  // Cloudinary public_id for deletion
  trade     Trade    @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  tradeId   String
  createdAt DateTime @default(now())
}

model DailyJournal {
  id             String             @id @default(cuid())
  date           DateTime
  notes          String
  mood           String?            // BULLISH, BEARISH, NEUTRAL
  lessons        String?
  // AI-ready fields
  energyLevel    Int?               // 1-10 physical state
  sleepQuality   Int?               // 1-10 rest quality
  focusLevel     Int?               // 1-10 mental clarity
  premarketPlan  Boolean            @default(false) // Did user have a premarket plan?
  sentimentScore Float?             // AI-computed from notes (-1 to 1)
  screenshots    JournalScreenshot[]
  embedding      JournalEmbedding?
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([userId, date])
}

model JournalScreenshot {
  id        String       @id @default(cuid())
  journalId String
  journal   DailyJournal @relation(fields: [journalId], references: [id], onDelete: Cascade)
  filename  String
  path      String       // Cloudinary URL
  publicId  String?      // Cloudinary public_id for deletion
  createdAt DateTime     @default(now())
}

model Settings {
  id               String   @id @default(cuid())
  defaultRisk      Float    @default(100) // Default R value for R-multiple
  currency         String   @default("USD")
  theme            String   @default("light")
  defaultAccountId String?  // Default account for new trades
  defaultAccount   Account? @relation(fields: [defaultAccountId], references: [id], onDelete: SetNull)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String   @unique
}

// AI Embedding models for RAG (Ask Your Journal feature)
model TradeEmbedding {
  id        String   @id @default(cuid())
  tradeId   String   @unique
  trade     Trade    @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  chunkText String   // Text chunk that was embedded (notes + setup + tags)
  embedding String   // JSON serialized vector (for SQLite compatibility)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JournalEmbedding {
  id        String       @id @default(cuid())
  journalId String       @unique
  journal   DailyJournal @relation(fields: [journalId], references: [id], onDelete: Cascade)
  chunkText String       // Text chunk that was embedded (notes + lessons)
  embedding String       // JSON serialized vector (for SQLite compatibility)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

// AI Weekly Performance Coach Reports
model WeeklyCoachReport {
  id                String   @id @default(cuid())
  weekStart         DateTime // Monday of the week
  weekEnd           DateTime // Sunday of the week

  // Input metrics (stored for historical reference)
  totalTrades       Int
  winRate           Float
  totalPnl          Float
  avgWinnerR        Float
  avgLoserR         Float
  executionRate     Float

  // Psychology aggregates
  avgConfidence     Float?   // Average confidence level for the week
  mostCommonMistake String?  // Most frequent mistake type
  moodDistribution  String?  // JSON: { "CONFIDENT": 5, "ANXIOUS": 2, ... }

  // AI-generated content
  summary           String   // 2-3 sentence executive summary
  strengths         String   // JSON array of strengths identified
  improvements      String   // JSON array of areas for improvement
  actionItems       String   // JSON array of specific action items

  // Metadata
  modelVersion      String   @default("llama-3.3-70b-versatile")
  generatedAt       DateTime @default(now())

  // Relations
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String
  accountId         String?  // null means Paper Account

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([userId, accountId, weekStart])
}
